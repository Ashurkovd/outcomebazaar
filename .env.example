# Private key for deployment (without 0x prefix)
# WARNING: Never commit your actual .env file with real keys!
PRIVATE_KEY=your_private_key_here

# Polygon Mainnet RPC URL
# You can get free RPC URLs from:
# - Alchemy: https://www.alchemy.com/
# - Infura: https://infura.io/
# - QuickNode: https://www.quicknode.com/
POLYGON_RPC=https://polygon-rpc.com

# Amoy Testnet RPC URL
AMOY_RPC=https://rpc-amoy.polygon.technology

# PolygonScan API Key for contract verification
# Get one from: https://polygonscan.com/apis
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# ============================================
# ANALYTICS CONFIGURATION (Frontend)
# ============================================

# Analytics Provider
# Options: 'none', 'google', 'plausible', 'both'
# Default: 'none' (disabled)
REACT_APP_ANALYTICS_PROVIDER=plausible

# Google Analytics (if using 'google' or 'both')
# Get your Measurement ID from https://analytics.google.com
# Format: G-XXXXXXXXXX
REACT_APP_GA_MEASUREMENT_ID=

# Plausible Analytics (if using 'plausible' or 'both')
# Recommended: Privacy-focused, no cookies, GDPR compliant
# Domain should match your deployment domain
REACT_APP_PLAUSIBLE_DOMAIN=outcomebazaar.app
REACT_APP_PLAUSIBLE_ENABLED=true
# Optional: Self-hosted Plausible API host (default: https://plausible.io)
REACT_APP_PLAUSIBLE_API_HOST=https://plausible.io
