# ═══════════════════════════════════════════════════════════
# OutcomeBazaar Order Book - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ═══════════════════════════════════════════════════════════

# ─── Blockchain ───────────────────────────────────────────
# Polygon RPC URL (get a free one at https://www.alchemy.com or https://infura.io)
RPC_URL=https://polygon-rpc.com

# Your wallet's private key (the oracle/admin wallet)
# This is used to: create market conditions, resolve markets
PRIVATE_KEY=your_64_char_hex_private_key_here

# Network: polygon (mainnet) or amoy (testnet)
NETWORK=polygon

# ─── Database ─────────────────────────────────────────────
# Railway PostgreSQL URL format:
# postgresql://user:password@host.railway.app:port/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/outcomebazaar

# ─── Server ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Frontend URL for CORS (your Vercel deployment)
FRONTEND_URL=https://outcomebazaar.vercel.app

# ─── Admin ────────────────────────────────────────────────
# Secret key for admin API endpoints (market creation, resolution)
# Generate a random 32-char string: openssl rand -hex 16
ADMIN_API_KEY=generate_a_random_secret_here

# ─── Smart Contracts (already deployed, don't change) ─────
CTF_ADDRESS=0x4D97DCd97eC945f40cF65F87097ACe5EA0476045
USDT_ADDRESS=0xc2132D05D31c914a87C6611C10748AEb04B58e8F
